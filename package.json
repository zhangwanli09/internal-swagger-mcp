{
  "name": "swagger-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for querying internal Swagger API documentation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "serve": "node dist/server.js",
    "dev": "tsx watch src/index.ts",
    "dev:serve": "tsx watch src/server.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
